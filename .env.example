# NetScanX — Konfiguration
# Kopiere diese Datei nach .env und passe die Werte an.

# Dashboard
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8080

# Scan-Defaults
DEFAULT_TIMEOUT=2.0
DEFAULT_CONCURRENCY=100

# MAC-Vendor-Lookup (online API, 1 req/s rate limit)
VENDOR_LOOKUP=true

# SNMP Community String
SNMP_COMMUNITY=public
